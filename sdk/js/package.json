{
  "name": "@simpleauth/js",
  "version": "1.0.0",
  "description": "JavaScript/TypeScript SDK for SimpleAuth — zero-dependency, works in Node.js and browsers",
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": {
      "import": "./index.ts",
